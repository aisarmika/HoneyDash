DATABASE_URL=postgresql+asyncpg://honeydash:honeydash_pass@postgres:5432/honeydash
COWRIE_LOG_PATH=/var/log/cowrie/cowrie.json
VIRUSTOTAL_API_KEY=
SECRET_KEY=change-this-to-a-random-secret-in-production
ADMIN_EMAIL=admin@honeydash.local
# Generate a bcrypt hash, for example:
# docker compose run --rm --no-deps backend python -c "import bcrypt; print(bcrypt.hashpw(b'Admin@12345', bcrypt.gensalt()).decode())"
# If left empty on a fresh database, HoneyDash seeds admin@honeydash.local with password: admin
ADMIN_PASSWORD_HASH=
LOG_CATCHUP_ON_START=false
VT_RATE_LIMIT_SECONDS=15
ENRICHMENT_CACHE_HOURS=24
SENSOR_API_KEY=change-this-sensor-key
